FROM ros:humble

# using devcontainer is nice cause it'll remap uid's/gid's for us
ARG USERNAME=autonomous
ARG USER_UID=1000
ARG USER_GID=${USER_UID}

SHELL ["/bin/bash", "-c"]

# Create the user
RUN groupadd --gid ${USER_GID} ${USERNAME} \
    && useradd --uid ${USER_UID} --gid ${USER_GID} -m ${USERNAME} \
    && apt update \
    && apt install -y sudo \
    && echo ${USERNAME} ALL=\(root\) NOPASSWD:ALL > /etc/sudoers.d/${USERNAME} \
    && chmod 0440 /etc/sudoers.d/${USERNAME}

# install apt packages
COPY docker/deps/packages.txt deps/packages.txt
RUN apt update && apt install -q -y --no-install-recommends \
    $(cat deps/packages.txt) \
    && rm -rf /var/lib/apt/lists/* && apt-get clean

# install clang tooling (version 18)
RUN wget https://apt.llvm.org/llvm.sh \
    && chmod +x llvm.sh \
    && ./llvm.sh 18 \
    && apt update && apt install -y \
    clang-tools-18 \
    clang-tidy-18 \
    clang-format-18

# install python packages
COPY docker/deps/requirements.txt deps/requirements.txt
RUN python3 -m pip install --upgrade pip
RUN python3 -m pip install --upgrade --ignore-installed -r deps/requirements.txt

# setup bashrc
RUN echo -e "\nsource /f1tenth/scripts/formula_bashrc.sh" >> /home/${USERNAME}/.bashrc

RUN git config --global --add safe.directory /f1tenth

ENV IS_JETSON=FALSE

# Install tools for simulator
RUN apt-get update --fix-missing && \
    apt-get install -y git \
    vim \
    tmux \
    python3-pip \
    libeigen3-dev \
    ros-humble-rviz2 \
    ros-humble-rmw-cyclonedds-cpp
RUN apt-get -y dist-upgrade
RUN pip3 install transforms3d

# install CDT (Constrained Delaunay Triangulation)
RUN git clone https://github.com/artem-ogre/CDT.git && \
    cmake -S CDT/CDT -B CDT/build -DCDT_USE_AS_COMPILED_LIBRARY=ON && \
    cmake --build CDT/build && \
    cmake --install CDT/build && \
    rm -rf CDT

RUN apt-get update && \
    apt-get install -y \
        qt6-base-dev \
        qt6-base-dev-tools \
        qt6-tools-dev \
        qmake6 \
        build-essential \
        python3-dev

COPY . /tmp/workspace
RUN cd /tmp/workspace/src/simulation/f1tenth_gym && \
    pip3 install .

# install f1tenth_gym_ros dependencies
RUN source /opt/ros/humble/setup.bash && \
    cd /tmp/workspace && \
    rosdep update && \
    rosdep install -i --from-path src --rosdistro humble -y

RUN apt-get update && \
    apt-get install -y ros-humble-asio-cmake-module

RUN rm -rf /tmp/workspace

USER ${USERNAME}
ENTRYPOINT [ "/bin/bash" ]
